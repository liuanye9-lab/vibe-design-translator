# Vibe Design Translator - Environment Variables
# Copy this file to .env.local and fill in your values.
# DO NOT commit .env.local to version control.

# ============================================================
# AI Provider Configuration
# ============================================================

# AI provider to use: mock, openai, claude, gemini, mimo, agnes
AI_PROVIDER=mock

# Set to "true" to use real AI providers instead of mock
ENABLE_REAL_AI=false

# Enable vision diagnosis (requires real AI provider with vision support)
ENABLE_VISION_DIAGNOSIS=false

# ============================================================
# API Keys (only needed when ENABLE_REAL_AI=true)
# ============================================================

# OpenAI API key - required for openai provider (GPT-4o vision)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OpenAI model names
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_TEXT_MODEL=gpt-4o-mini

# Anthropic API key - required for claude provider (Claude 3.5 Sonnet)
# Get from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=

# Claude model name
CLAUDE_TEXT_MODEL=claude-3-5-sonnet-latest

# Google Gemini API key - required for gemini provider
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Gemini model names
GEMINI_VISION_MODEL=gemini-1.5-flash
GEMINI_TEXT_MODEL=gemini-1.5-flash

# Mimo API key - required for mimo provider (mimo-v2.5-pro)
# Get from: https://token-plan-cn.xiaomimimo.com
MIMO_API_KEY=
MIMO_API_BASE=https://token-plan-cn.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5-pro

# Agnes API key - required for agnes provider
AGNES_API_KEY=
AGNES_API_BASE=https://apihub.agnes-ai.com/v1
AGNES_TEXT_MODEL=agnes-2.0-flash
AGNES_IMAGE_MODEL=agnes-image-2.0-flash
AGNES_VIDEO_MODEL=agnes-video-v2.0

# ============================================================
# Notes
# ============================================================
# - All variables are server-side only (NOT exposed to client)
# - API keys are used server-side only (in app/api/ routes)
# - Mock provider is used when ENABLE_REAL_AI=false or API key is missing
# - AI provider failures gracefully fall back to mock automatically
# - Default: mock provider (no API keys needed)
# - NEVER use NEXT_PUBLIC_* for API keys or sensitive configuration
