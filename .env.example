# ============================================================
# Vibe Design Translator - Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to version control
# ============================================================

# ============================================================
# AI Provider Configuration
# ============================================================

# Current provider: mock | openai | claude | gemini | mimo
NEXT_PUBLIC_AI_PROVIDER=mock

# Enable real AI (requires API keys to be configured)
# Set to "true" only after configuring API keys below
NEXT_PUBLIC_ENABLE_REAL_AI=false

# ============================================================
# OpenAI Configuration
# ============================================================

# Get your API key from: https://platform.openai.com/api-keys
# Format: sk-...
OPENAI_API_KEY=

# ============================================================
# Anthropic (Claude) Configuration
# ============================================================

# Get your API key from: https://console.anthropic.com/settings/keys
# Format: sk-ant-...
ANTHROPIC_API_KEY=

# ============================================================
# Google Gemini Configuration
# ============================================================

# Get your API key from: https://makersuite.google.com/app/apikey
# Format: AIza...
GEMINI_API_KEY=

# ============================================================
# Vision Diagnosis
# ============================================================

# Enable vision diagnosis with real AI
# Note: Requires one of the above API keys to be configured
NEXT_PUBLIC_ENABLE_VISION_DIAGNOSIS=false

# ============================================================
# Feature Flags
# ============================================================

# Enable user authentication (future feature)
NEXT_PUBLIC_ENABLE_AUTH=false

# Enable cloud sync (future feature)
NEXT_PUBLIC_ENABLE_CLOUD_SYNC=false

# ============================================================
# App Configuration
# ============================================================

# App URL (for callbacks, webhooks, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000
