# Vibe Design Translator - Environment Variables
# Copy this file to .env.local and fill in your values.
# DO NOT commit .env.local to version control.

# ============================================================
# AI Provider Configuration
# ============================================================

# AI provider to use: mock, openai, claude, gemini
NEXT_PUBLIC_AI_PROVIDER=mock

# Set to "true" to use real AI providers instead of mock
NEXT_PUBLIC_ENABLE_REAL_AI=false

# Enable vision diagnosis (requires real AI provider with vision support)
NEXT_PUBLIC_ENABLE_VISION_DIAGNOSIS=false

# ============================================================
# API Keys (only needed when ENABLE_REAL_AI=true)
# ============================================================

# OpenAI API key - required for openai provider (GPT-4o vision)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic API key - required for claude provider (Claude 3.5 Sonnet)
# Get from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=

# Google API key - required for gemini provider (gemini-2.0-flash)
# Get from: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# ============================================================
# Notes
# ============================================================
# - API keys are used server-side only (in app/api/ routes)
# - Mock provider is used when ENABLE_REAL_AI=false or API key is missing
# - AI provider failures gracefully fall back to mock automatically
# - Default: mock provider (no API keys needed)
